<!DOCTYPE html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content={get_csrf_token()}>
    <title>Azar Server</title>
    <link phx-track-static rel="stylesheet" href={~p"/css/app.css"}>
    <script defer phx-track-static type="text/javascript" src={~p"/js/i18n-theme.js"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/js/app.js"}></script>
  </head>
  <body>
    <div class="container">
      <aside class="sidebar">
        <nav class="nav">
          <div class="logo-section">
            <h1 class="logo">Azar</h1>
            <p class="subtitle" data-i18n="common.app_name">Admin Central</p>
          </div>

          <ul class="nav-menu">
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">S</span>
                <span class="nav-text" data-i18n="nav.draws">Sorteos</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">T</span>
                <span class="nav-text" data-i18n="nav.tickets">Billetes</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">F</span>
                <span class="nav-text" data-i18n="nav.fractions">Fracciones</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">P</span>
                <span class="nav-text" data-i18n="nav.prizes">Premios</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">R</span>
                <span class="nav-text" data-i18n="nav.reports">Reportes</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="nav-icon">A</span>
                <span class="nav-text" data-i18n="nav.audit">Auditoría</span>
              </a>
            </li>
          </ul>

          <div class="nav-footer">
            <p class="version">v0.1.0</p>
          </div>
        </nav>
      </aside>

      <main class="main-content">
        <header class="topbar">
          <div class="topbar-left">
            <h2 class="page-title"><%= assigns[:page_title] || "Dashboard" %></h2>
          </div>
          <div class="topbar-right">
            <div class="user-menu">
              <span class="user-name">Admin</span>
            </div>
          </div>
        </header>

        <div class="content">
          <%= @inner_content %>
        </div>
      </main>
    </div>

    <!-- Controls Bar for Theme and Language -->
    <div class="controls-bar">
      <select id="language-select" aria-label="Select Language">
        <option value="es">Español</option>
        <option value="en">English</option>
      </select>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme" title="Toggle Dark/Light Mode">
        🌙
      </button>
    </div>
  </body>
</html>
