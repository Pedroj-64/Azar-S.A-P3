# Gitignore for Azar Server

# The directory Mix will write its output to.
/_build/

# The directory Mix downloads your dependencies source code to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in dependencies.
/.fetch

# If the elixir_ls directory has been added to your .gitignore rules, you can
# delete this file.  The elixir-ls extension will issue a warning if .gitignore
# is missing this entry.
/.elixir_ls/

# Testing
/cover/

# The MIX_ENV file
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Build artifacts
*.beam
erl_crash.dump

# Dialyzer
.dialyzer_plt
.dialyzer_plt_*

# Logs
/logs/
*.log

# JSON data files (local development only)
priv/data/*.json
!priv/data/.gitkeep

# Release
/rel/
