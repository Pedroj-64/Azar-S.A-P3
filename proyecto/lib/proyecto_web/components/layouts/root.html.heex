<!DOCTYPE html>
<html lang={Gettext.get_locale(ProyectoWeb.Gettext)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content="Azar S.A. — Lotería. La suerte tiene su propio sabor." />
    <.live_title default="Azar S.A." suffix=" · Lotería">
      {assigns[:page_title]}
    </.live_title>

    <%!-- Fuentes retro: Cooper Black lookalike + monospace vintage --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Spectral:ital,wght@0,600;0,800;1,600&display=swap" rel="stylesheet" />

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>

    <style>
      /* ── SISTEMA DE COLORES VINTAGE VEGAS ─────────────── */
      :root {
        --mostaza:      #d4a017;
        --naranja:      #c2521a;
        --chocolate:    #3d1f0d;
        --chocolate-md: #5a2e10;
        --chocolate-lt: #7a3f18;
        --teal:         #2a6b6b;
        --teal-lt:      #3a8a8a;
        --crema:        #f0e6c8;
        --crema-oscura: #c8b48a;
        --humo:         rgba(212, 160, 23, 0.06);
        --neon-orange:  #ff6b1a;
        --neon-gold:    #ffd700;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Spectral', Georgia, serif;
        background-color: var(--chocolate);
        color: var(--crema);
        overflow-x: hidden;
        position: relative;
      }

      /* ── TIPOGRAFÍA ───────────────────────────────────── */
      .font-display  { font-family: 'Alfa Slab One', serif; }
      .font-serif    { font-family: 'Playfair Display', Georgia, serif; }
      .font-mono     { font-family: 'DM Mono', monospace; }
      .font-body     { font-family: 'Spectral', Georgia, serif; }

      /* ── GRANO VHS (Canvas JS lo pinta encima) ────────── */
      #vhs-overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        pointer-events: none;
        z-index: 9998;
        opacity: 0.045;
        mix-blend-mode: screen;
      }

      /* ── PATRÓN DE ALFOMBRA ───────────────────────────── */
      .carpet-bg {
        background-color: var(--chocolate);
        background-image:
          /* Rombo grande */
          repeating-linear-gradient(
            45deg,
            transparent,
            transparent 18px,
            rgba(212,160,23,0.07) 18px,
            rgba(212,160,23,0.07) 20px
          ),
          repeating-linear-gradient(
            -45deg,
            transparent,
            transparent 18px,
            rgba(42,107,107,0.07) 18px,
            rgba(42,107,107,0.07) 20px
          ),
          /* Cuadrícula fina */
          repeating-linear-gradient(
            0deg,
            transparent,
            transparent 39px,
            rgba(212,160,23,0.04) 39px,
            rgba(212,160,23,0.04) 40px
          ),
          repeating-linear-gradient(
            90deg,
            transparent,
            transparent 39px,
            rgba(212,160,23,0.04) 39px,
            rgba(212,160,23,0.04) 40px
          );
      }

      /* ── NEÓN DE GAS VINTAGE (tubos viejos, mal contacto) ─── */

      /* Naranja: tubo de neón con gas agotándose — parpadea y se apaga */
      .neon-gas {
        text-shadow:
          0 0 3px  rgba(255, 107, 26, 0.7),
          0 0 10px rgba(255, 107, 26, 0.35),
          0 0 25px rgba(255, 107, 26, 0.12);
        animation: gas-sputter 18s infinite;
      }

      /* Dorado: tubo viejo que hace contacto intermitente */
      .neon-gold {
        text-shadow:
          0 0 3px  rgba(255, 215, 0, 0.7),
          0 0 10px rgba(255, 215, 0, 0.3),
          0 0 22px rgba(212, 160, 23, 0.1);
        animation: gold-dying 22s infinite 3s;
      }

      /* Teal: tubo de mercurio con zumbido eléctrico */
      .neon-teal {
        text-shadow:
          0 0 3px  rgba(42, 200, 200, 0.7),
          0 0 10px rgba(42, 200, 200, 0.3),
          0 0 20px rgba(42, 107, 107, 0.1);
        animation: teal-buzz 15s infinite 7s;
      }

      /*
       * ANIMACIÓN 1: Gas sputtering — se apaga por completo un instante,
       * intenta prender 2 veces rápido, y luego vuelve.
       */
      @keyframes gas-sputter {
        0%, 100%  { opacity: 1; }
        /* Funcionando normal... */
        62%       { opacity: 1; }
        /* Parpadeo rápido previo al apagón */
        63%       { opacity: 0.4; }
        63.5%     { opacity: 0.9; }
        64%       { opacity: 0.3; }
        64.5%     { opacity: 0.85; }
        /* Apagón breve */
        65%       { opacity: 0.08; }
        66.5%     { opacity: 0.08; }
        /* Intenta prender */
        67%       { opacity: 0.5; }
        67.3%     { opacity: 0.15; }
        /* Prende de nuevo */
        68%       { opacity: 0.7; }
        69%       { opacity: 1; }
        /* Micro-flicker más tarde */
        85%       { opacity: 1; }
        85.5%     { opacity: 0.6; }
        86%       { opacity: 1; }
      }

      /*
       * ANIMACIÓN 2: Tubo dorado agonizante — se va debilitando
       * gradualmente, casi muere, y luego vuelve con fuerza.
       */
      @keyframes gold-dying {
        0%, 100%  { opacity: 1; }
        /* Normal... */
        40%       { opacity: 1; }
        /* Empieza a debilitarse */
        42%       { opacity: 0.7; }
        44%       { opacity: 0.5; }
        46%       { opacity: 0.25; }
        /* Casi muerto */
        48%       { opacity: 0.1; }
        49%       { opacity: 0.1; }
        /* Intento de resurrección — stutter triple */
        49.5%     { opacity: 0.6; }
        50%       { opacity: 0.15; }
        50.5%     { opacity: 0.7; }
        51%       { opacity: 0.2; }
        51.5%     { opacity: 0.8; }
        /* Vuelve a la vida */
        53%       { opacity: 1; }
        /* Micro-parpadeo secundario */
        78%       { opacity: 1; }
        78.5%     { opacity: 0.5; }
        79%       { opacity: 0.85; }
        79.5%     { opacity: 1; }
      }

      /*
       * ANIMACIÓN 3: Zumbido de mercurio — vibraciones rápidas
       * como un transformador que hace ruido.
       */
      @keyframes teal-buzz {
        0%, 100%  { opacity: 1; }
        /* Normal... */
        30%       { opacity: 1; }
        /* Buzz eléctrico: vibraciones rápidas */
        30.3%     { opacity: 0.7; }
        30.6%     { opacity: 0.95; }
        30.9%     { opacity: 0.6; }
        31.2%     { opacity: 0.9; }
        31.5%     { opacity: 0.55; }
        31.8%     { opacity: 0.85; }
        32%       { opacity: 1; }
        /* Apagón limpio más tarde */
        72%       { opacity: 1; }
        73%       { opacity: 0.1; }
        74.5%     { opacity: 0.1; }
        75%       { opacity: 0.4; }
        75.3%     { opacity: 0.12; }
        76%       { opacity: 0.8; }
        77%       { opacity: 1; }
      }

      /* ── HALO VINTAGE CON PULSO ────────────────────────── */
      .halo {
        box-shadow:
          0 0 6px  rgba(212, 160, 23, 0.15),
          0 0 18px rgba(212, 160, 23, 0.07);
        animation: halo-pulse 8s ease-in-out infinite;
      }
      .halo-teal {
        box-shadow:
          0 0 6px  rgba(42, 107, 107, 0.2),
          0 0 18px rgba(42, 107, 107, 0.08);
        animation: halo-pulse 10s ease-in-out infinite 2s;
      }
      .halo-orange {
        box-shadow:
          0 0 6px  rgba(194, 82, 26, 0.22),
          0 0 18px rgba(194, 82, 26, 0.09);
        animation: halo-pulse 9s ease-in-out infinite 5s;
      }

      /* Pulso suave — el halo "respira" como un foco incandescente */
      @keyframes halo-pulse {
        0%, 100% { filter: brightness(1); }
        50%      { filter: brightness(1.08); }
      }

      /* ── TARJETA VINTAGE ──────────────────────────────── */
      .vintage-card {
        background: linear-gradient(135deg, var(--chocolate-md) 0%, #4a2412 100%);
        border: 1px solid rgba(212, 160, 23, 0.3);
        border-radius: 4px;
        position: relative;
        overflow: hidden;
        transition: box-shadow 0.4s ease, border-color 0.4s ease;
      }
      .vintage-card:hover {
        box-shadow: 0 0 12px rgba(212, 160, 23, 0.08);
        border-color: rgba(212, 160, 23, 0.45);
      }
      .vintage-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          45deg,
          transparent,
          transparent 3px,
          rgba(212,160,23,0.015) 3px,
          rgba(212,160,23,0.015) 4px
        );
        pointer-events: none;
      }
      /* Borde interior dorado fino */
      .vintage-card::after {
        content: '';
        position: absolute;
        inset: 4px;
        border: 1px solid rgba(212, 160, 23, 0.15);
        border-radius: 2px;
        pointer-events: none;
      }

      /* ── INPUT VINTAGE ────────────────────────────────── */
      .vintage-input {
        background: var(--chocolate);
        border: 1px solid rgba(212, 160, 23, 0.35);
        border-radius: 2px;
        color: var(--crema);
        font-family: 'DM Mono', monospace;
        font-size: 0.875rem;
        padding: 0.75rem 1rem;
        width: 100%;
        transition: border-color 0.3s, box-shadow 0.3s;
        outline: none;
      }
      .vintage-input::placeholder {
        color: var(--crema-oscura);
        opacity: 0.5;
        font-style: italic;
      }
      .vintage-input:focus {
        border-color: var(--mostaza);
        box-shadow: 0 0 0 2px rgba(212,160,23,0.15), 0 0 12px rgba(212,160,23,0.1);
      }

      /* ── BOTÓN PALANCA / INTERRUPTOR ─────────────────── */
      .btn-lever {
        position: relative;
        background: linear-gradient(180deg, var(--naranja) 0%, #9c3e12 100%);
        color: var(--crema);
        font-family: 'Alfa Slab One', serif;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.8rem 2rem;
        border: none;
        border-radius: 2px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: transform 0.1s, box-shadow 0.2s;
        box-shadow:
          0 4px 0 #6b2a0a,
          0 6px 12px rgba(0,0,0,0.4),
          inset 0 1px 0 rgba(255,255,255,0.15);
        transform: translateY(0);
      }
      .btn-lever:hover {
        background: linear-gradient(180deg, #d4601e 0%, #a84215 100%);
        box-shadow:
          0 4px 0 #6b2a0a,
          0 8px 16px rgba(194,82,26,0.3),
          0 0 20px rgba(255, 107, 26, 0.12),
          inset 0 1px 0 rgba(255,255,255,0.2);
        text-shadow: 0 0 4px rgba(255, 200, 100, 0.3);
      }
      .btn-lever:active {
        transform: translateY(3px);
        box-shadow:
          0 1px 0 #6b2a0a,
          0 2px 8px rgba(0,0,0,0.3),
          inset 0 1px 0 rgba(255,255,255,0.1);
      }

      .btn-lever-teal {
        background: linear-gradient(180deg, var(--teal-lt) 0%, #1d4d4d 100%);
        box-shadow:
          0 4px 0 #112e2e,
          0 6px 12px rgba(0,0,0,0.4),
          inset 0 1px 0 rgba(255,255,255,0.12);
      }
      .btn-lever-teal:hover {
        background: linear-gradient(180deg, #469090 0%, #235858 100%);
      }
      .btn-lever-ghost {
        background: transparent;
        border: 1px solid rgba(212,160,23,0.4);
        box-shadow: none;
        color: var(--mostaza);
      }
      .btn-lever-ghost:hover {
        background: rgba(212,160,23,0.08);
        box-shadow: 0 0 12px rgba(212,160,23,0.15);
      }
      .btn-lever-ghost:active { transform: translateY(1px); }

      /* ── TRANSICIÓN PROYECTOR ─────────────────────────── */
      .page-enter {
        animation: projector-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      @keyframes projector-in {
        0%   { opacity: 0; filter: brightness(1.8) blur(3px); transform: scale(1.015); }
        30%  { opacity: 1; filter: brightness(1.1) blur(0px); }
        100% { opacity: 1; filter: brightness(1)   blur(0px); transform: scale(1); }
      }

      /* ── BADGE / ETIQUETA VINTAGE ─────────────────────── */
      .vintage-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(212,160,23,0.12);
        border: 1px solid rgba(212,160,23,0.3);
        border-radius: 2px;
        padding: 0.25rem 0.75rem;
        font-family: 'DM Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mostaza);
      }

      /* ── DIVISOR ORNAMENTAL ───────────────────────────── */
      .divider-ornament {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(212,160,23,0.4);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
      }
      .divider-ornament::before,
      .divider-ornament::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(212,160,23,0.4), transparent);
      }

      /* ── LENS FLARE DECORATIVO ────────────────────────── */
      .lens-flare {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
      }
      .lens-flare-1 {
        width: 300px; height: 300px;
        background: radial-gradient(circle,
          rgba(212,160,23,0.12) 0%,
          rgba(194,82,26,0.06) 40%,
          transparent 70%
        );
        filter: blur(20px);
      }
      .lens-flare-2 {
        width: 500px; height: 200px;
        background: radial-gradient(ellipse,
          rgba(255,200,50,0.06) 0%,
          transparent 70%
        );
        filter: blur(30px);
      }

      /* ── SCROLLBAR VINTAGE ────────────────────────────── */
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: var(--chocolate); }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, var(--naranja), var(--chocolate-lt));
        border-radius: 0;
      }

      /* ── STATUS BADGE (indicadores luminosos) ────────── */
      .badge-pending {
        background: rgba(212,160,23,0.15);
        border: 1px solid rgba(212,160,23,0.3);
        color: var(--mostaza);
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border-radius: 1px;
        text-shadow: 0 0 4px rgba(255, 215, 0, 0.4);
        box-shadow: 0 0 4px rgba(212,160,23,0.1);
        animation: gold-dying 22s infinite 8s;
      }
      .badge-done {
        background: rgba(42,107,107,0.2);
        border: 1px solid rgba(42,107,107,0.4);
        color: var(--teal-lt);
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border-radius: 1px;
        text-shadow: 0 0 4px rgba(42, 200, 200, 0.3);
        box-shadow: 0 0 4px rgba(42,107,107,0.1);
      }

      /* ── SIDEBAR LINK (signage iluminada) ──────────────── */
      .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 1rem;
        border-radius: 2px;
        color: var(--crema-oscura);
        font-family: 'DM Mono', monospace;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s, box-shadow 0.2s, text-shadow 0.3s;
        border-left: 2px solid transparent;
        text-decoration: none;
      }
      .sidebar-link:hover {
        background: rgba(212,160,23,0.08);
        color: var(--mostaza);
        border-left-color: var(--mostaza);
        box-shadow: inset 0 0 20px rgba(212,160,23,0.06);
        text-shadow: 0 0 6px rgba(255, 215, 0, 0.3);
      }
    </style>
  </head>
  <body class="carpet-bg">
    <%!-- Canvas para grano VHS --%>
    <canvas id="vhs-overlay" aria-hidden="true"></canvas>

    <div class="page-enter" id="page-root">
      {@inner_content}
    </div>

    <script>
      // ── GRANO VHS ─────────────────────────────────────────────────
      (function() {
        const canvas = document.getElementById('vhs-overlay');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let animId;

        function resize() {
          canvas.width  = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        function drawGrain() {
          const { width, height } = canvas;
          const imgData = ctx.createImageData(width, height);
          const data = imgData.data;
          for (let i = 0; i < data.length; i += 4) {
            const v = Math.random() * 255 | 0;
            data[i]     = v;   // R
            data[i + 1] = v;   // G
            data[i + 2] = v * 0.7 | 0; // B (calidez sepia)
            data[i + 3] = Math.random() > 0.5 ? 40 : 0; // opacidad aleatoria
          }
          ctx.putImageData(imgData, 0, 0);
          animId = requestAnimationFrame(drawGrain);
        }
        drawGrain();
      })();

      // ── TRANSICIÓN PROYECTOR entre páginas LiveView ───────────────
      window.addEventListener('phx:page-loading-start', () => {
        const el = document.getElementById('page-root');
        if (el) el.style.opacity = '0';
      });
      window.addEventListener('phx:page-loading-stop', () => {
        const el = document.getElementById('page-root');
        if (!el) return;
        el.style.opacity = '';
        el.classList.remove('page-enter');
        void el.offsetWidth; // reflow
        el.classList.add('page-enter');
      });
    </script>
  </body>
</html>
